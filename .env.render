# Copy these values into Render Environment Variables.
DEBUG=0
SECRET_KEY=replace-with-a-real-secret-key
ALLOWED_HOSTS=your-render-service.onrender.com
# CSRF_TRUSTED_ORIGINS=https://your-render-service.onrender.com

# Render usually injects DATABASE_URL from attached Postgres.
# DATABASE_URL=postgres://...
DB_SSL_REQUIRE=1

OPENWEATHER_API_KEY=

LIVE_UPDATES_POLL_SECONDS=5
MAX_DASHBOARD_SHIPMENTS=25
WEATHER_CACHE_TTL_SECONDS=300
TRAFFIC_CACHE_TTL_SECONDS=180

# If Ollama is not reachable from Render, keep defaults or point to a hosted endpoint.
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=gemma3:latest
OLLAMA_TIMEOUT_SECONDS=10
AI_EXPLANATION_TTL_MINUTES=10
