DEBUG=1
SECRET_KEY=dev-secret-key-change-me
ALLOWED_HOSTS=127.0.0.1,localhost
# CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Render will provide DATABASE_URL for Postgres automatically if you attach a DB.
# For local Postgres you can set something like:
# DATABASE_URL=postgres://user:password@localhost:5432/control_tower
# DB_SSL_REQUIRE=1

# Optional: if set, OpenWeatherMap will be used. Otherwise the app falls back to Open-Meteo (no key).
# OPENWEATHER_API_KEY=

# Poll interval for HTMX dashboard
LIVE_UPDATES_POLL_SECONDS=5

# Optional local Ollama/Gemma settings
# OLLAMA_URL=http://localhost:11434/api/generate
# OLLAMA_MODEL=gemma3:latest
# OLLAMA_TIMEOUT_SECONDS=10
